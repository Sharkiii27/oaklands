function ShowToast(message, type)
    type = type or "info"

    local iconMap = {
        success = "✓",
        info = "ℹ",
        warn = "⚠",
        error = "✕"
    }
    local colorMap = {
        success = Colors.success,
        info = Colors.info,
        warn = Colors.warning,
        error = Colors.danger
    }
    local dimMap = {
        success = Colors.successDim,
        info = Colors.infoDim,
        warn = Colors.warningDim,
        error = Colors.dangerDim
    }

    local toastColor = colorMap[type] or Colors.info
    local toastDim = dimMap[type] or Colors.infoDim

    local toast = Instance.new("Frame")
    toast.Size = UDim2.new(1, 0, 0, 44)
    toast.BackgroundColor3 = Colors.bgCard
    toast.BorderSizePixel = 0
    toast.Parent = ToastContainer
    MakeCorner(toast, 10)
    MakeStroke(toast, toastColor, 1, 0.8)
    AddGlow(toast, toastColor, UDim2.new(1, 20, 1, 12), UDim2.new(-0.05, -10, -0.05, -6))

    -- Animate in
    toast.Position = UDim2.new(0, 40, 0, 0)
    toast.BackgroundTransparency = 1
    TweenService:Create(toast, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
        Position = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 0
    }):Play()

    MakePadding(toast, 12, 10, 12, 10)

    local iconBg = Instance.new("Frame")
    iconBg.Size = UDim2.new(0, 24, 0, 24)
    iconBg.BackgroundColor3 = toastDim
    iconBg.BorderSizePixel = 0
    iconBg.Parent = toast
    MakeCorner(iconBg, 6)

    local iconL = Instance.new("TextLabel")
    iconL.Size = UDim2.new(1, 0, 1, 0)
    iconL.BackgroundTransparency = 1
    iconL.Text = iconMap[type] or "ℹ"
    iconL.TextColor3 = toastColor
    iconL.Font = Enum.Font.GothamBold
    iconL.TextSize = 12
    iconL.Parent = iconBg

    local msgLabel = Instance.new("TextLabel")
    msgLabel.Size = UDim2.new(1, -46, 1, 0)
    msgLabel.Position = UDim2.new(0, 34, 0, 0)
    msgLabel.BackgroundTransparency = 1
    msgLabel.Text = message
    msgLabel.TextColor3 = Colors.textPrimary
    msgLabel.TextXAlignment = Enum.TextXAlignment.Left
    msgLabel.Font = Enum.Font.GothamMedium
    msgLabel.TextSize = 13
    msgLabel.TextTruncate = Enum.TextTruncate.AtEnd
    msgLabel.Parent = toast

    -- Remove after delay
    task.delay(2.5, function()
        if toast and toast.Parent then
            TweenService:Create(toast, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {
                Position = UDim2.new(0, 40, 0, 0),
                BackgroundTransparency = 1
            }):Play()
            task.delay(0.3, function()
                if toast and toast.Parent then toast:Destroy() end
            end)
        end
    end)
end

