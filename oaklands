-- ==================== Helpers ====================
local function MakeCorner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 12)
    c.Parent = parent
    return c
end

local function MakeStroke(parent, color, thickness, transparency)
    local s = Instance.new("UIStroke")
    s.Color = color or Colors.border
    s.Thickness = thickness or 1
    s.Transparency = transparency or 0.94
    s.Parent = parent
    return s
end

local function MakePadding(parent, left, top, right, bottom)
    local p = Instance.new("UIPadding")
    p.PaddingLeft = UDim.new(0, left or 0)
    p.PaddingTop = UDim.new(0, top or 0)
    p.PaddingRight = UDim.new(0, right or 0)
    p.PaddingBottom = UDim.new(0, bottom or 0)
    p.Parent = parent
    return p
end

local function AddGlow(parent, color, size, position)
    local glow = Instance.new("ImageLabel")
    glow.Name = "Glow"
    glow.Size = size or UDim2.new(1, 40, 1, 20)
    glow.Position = position or UDim2.new(0, -20, 0, -10)
    glow.BackgroundTransparency = 1
    glow.Image = "rbxassetid://7669168585"
    glow.ImageColor3 = color or Colors.accent
    glow.ImageTransparency = 0.55
    glow.ScaleType = Enum.ScaleType.Slice
    glow.SliceCenter = Rect.new(100, 100, 100, 100)
    glow.ZIndex = -1
    glow.Parent = parent
    return glow
end

local function AddInnerGlow(parent, color, anchorX, anchorY)
    local glow = Instance.new("ImageLabel")
    glow.Name = "InnerGlow"
    glow.Size = UDim2.new(0.6, 0, 0.8, 0)
    glow.AnchorPoint = Vector2.new(anchorX or 0, anchorY or 0.5)
    glow.Position = UDim2.new(anchorX or 0, 0, 0.5, 0)
    glow.BackgroundTransparency = 1
    glow.Image = "rbxassetid://7669168585"
    glow.ImageColor3 = color or Colors.accent
    glow.ImageTransparency = 0.7
    glow.ScaleType = Enum.ScaleType.Slice
    glow.SliceCenter = Rect.new(100, 100, 100, 100)
    glow.ZIndex = 1
    glow.Parent = parent
    return glow
end

local function TweenButton(btn, state)
    local goal = {}
    if state == "hover" then
        goal.BackgroundColor3 = Colors.bgCardHover
        goal.ImageTransparency = 0.4
    elseif state == "press" then
        goal.BackgroundColor3 = Colors.bgCard
    elseif state == "release" then
        goal.BackgroundColor3 = Colors.bgCard
        goal.ImageTransparency = 0.55
    end

    local glow = btn:FindFirstChild("Glow")
    local targets = {btn}
    if glow then table.insert(targets, glow) end

    for _, t in ipairs(targets) do
        local validGoal = {}
        for k, v in pairs(goal) do
            if t[k] ~= nil then validGoal[k] = v end
        end
        if next(validGoal) then
            TweenService:Create(t, TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), validGoal):Play()
        end
    end
end

