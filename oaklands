-- Sidebar tab button
local function TabButton(text, callback)
	local b = Instance.new("TextButton")
	b.Size = UDim2.new(1,0,0,38)
	b.BackgroundColor3 = Theme.Element
	b.Text = text
	b.TextColor3 = Theme.Text
