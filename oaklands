--// FREECAM
local function ToggleFreecam()
	freecamActive = not freecamActive

	if freecamActive then
		freecamPart = Instance.new("Part")
		freecamPart.Anchored = true
		freecamPart.Transparency = 1
		freecamPart.CanCollide = false
		freecamPart.Size = Vector3.new(1,1,1)
		freecamPart.CFrame = Camera.CFrame
		freecamPart.Parent = Workspace

		Camera.CameraSubject = freecamPart
	else
		if freecamPart then freecamPart:Destroy() end
		if LocalPlayer.Character then
			Camera.CameraSubject = LocalPlayer.Character:FindFirstChild("Humanoid")
		end
	end
end

RunService.RenderStepped:Connect(function()
	if freecamActive and freecamPart then
		local dir = Vector3.zero
		local speed = 2.5

		if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir += Camera.CFrame.LookVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir -= Camera.CFrame.LookVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir -= Camera.CFrame.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir += Camera.CFrame.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.E) then dir += Vector3.new(0,1,0) end
		if UserInputService:IsKeyDown(Enum.KeyCode.Q) then dir -= Vector3.new(0,1,0) end

		freecamPart.CFrame += dir * speed
	end
end)

--// TELEPORT TREE
local function TeleportTree(part, pos)
	if not part then return end
	local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
	if not hrp then return end

	part.CFrame = hrp.CFrame * CFrame.new(0,0,-7)
	task.wait(0.15)

	local t = tick()
	while tick() - t < 0.8 do
		part.CFrame = CFrame.new(pos + Vector3.new(0,12,0))
		RunService.Heartbeat:Wait()
	end
end

--// FARM TAB
local function Farm()
	Clear()

	local t = Instance.new("TextButton")
	t.Size = UDim2.new(1,0,0,50)
	t.BackgroundColor3 = autoTreeTeleport and Color3.fromRGB(0,170,0) or Color3.fromRGB(170,0,0)
	t.Text = "Tree Teleport Toggle"
	t.TextColor3 = Color3.new(1,1,1)
	t.Parent = Content

	t.MouseButton1Click:Connect(function()
		autoTreeTeleport = not autoTreeTeleport
		Farm()
	end)

	local s = Instance.new("TextButton")
	s.Size = UDim2.new(1,0,0,50)
	s.BackgroundColor3 = Theme.Accent
	s.Text = "Set Target"
	s.TextColor3 = Color3.new(1,1,1)
	s.Parent = Content

	s.MouseButton1Click:Connect(function()
		if LocalPlayer.Character and LocalPlayer.Character.PrimaryPart then
			targetTreePos = LocalPlayer.Character.PrimaryPart.Position
		end
	end)
end

--// TELEPORT TAB
local function Teleports()
	Clear()

	local add = Instance.new("TextButton")
	add.Size = UDim2.new(1,0,0,50)
	add.BackgroundColor3 = Color3.fromRGB(0,180,100)
	add.Text = "Add Location"
	add.TextColor3 = Color3.new(1,1,1)
	add.Parent = Content

	add.MouseButton1Click:Connect(function()
		local pos = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
		if pos then
			table.insert(savedTeleports,{
				Name = "Point "..#savedTeleports+1,
				Position = pos.Position
			})
			Teleports()
		end
	end)

	for _,v in ipairs(savedTeleports) do
		local b = Instance.new("TextButton")
		b.Size = UDim2.new(1,0,0,40)
		b.Text = v.Name
		b.TextColor3 = Color3.new(1,1,1)
		b.Parent = Content

		b.MouseButton1Click:Connect(function()
			if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
				LocalPlayer.Character.HumanoidRootPart.CFrame =
					CFrame.new(v.Position + Vector3.new(0,5,0))
			end
		end)
	end
end

--// SETTINGS TAB
local function Settings()
	Clear()

	local f = Instance.new("TextButton")
	f.Size = UDim2.new(1,0,0,50)
	f.Text = "Toggle F Teleport"
	f.Parent = Content

	f.MouseButton1Click:Connect(function()
		clickTeleportPlayer = not clickTeleportPlayer
		Settings()
	end)

	local c = Instance.new("TextButton")
	c.Size = UDim2.new(1,0,0,50)
	c.Text = "Toggle Freecam"
	c.Parent = Content

	c.MouseButton1Click:Connect(function()
		ToggleFreecam()
		Settings()
	end)
end

--// INPUT
UserInputService.InputBegan:Connect(function(input,gp)
	if gp then return end

	if input.KeyCode == Enum.KeyCode.F and clickTeleportPlayer then
		local m = LocalPlayer:GetMouse()
		if m.Hit and LocalPlayer.Character then
			LocalPlayer.Character.HumanoidRootPart.CFrame =
				CFrame.new(m.Hit.Position + Vector3.new(0,3,0))
		end
	end

	if input.UserInputType == Enum.UserInputType.MouseButton1 and autoTreeTeleport then
		local m = LocalPlayer:GetMouse()
		if m.Target and targetTreePos then
			local model = m.Target:FindFirstAncestorOfClass("Model") or m.Target.Parent
			local part = model.PrimaryPart or m.Target
			TeleportTree(part, targetTreePos)
		end
	end
end)

