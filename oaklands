local function CreateGlowButton(config)
    -- config: {text, subtext, icon, style, statusText, onClick}
    -- styles: "toggle-on", "toggle-off", "action-info", "action-success", "action-warning"

    local style = config.style or "action-info"
    local isToggleOn = style == "toggle-on"
    local isToggleOff = style == "toggle-off"

    local accentColor, dimColor, glowColor
    if isToggleOn then
        accentColor, dimColor, glowColor = Colors.accent, Colors.accentDim, Colors.accent
    elseif isToggleOff then
        accentColor, dimColor, glowColor = Colors.danger, Colors.dangerDim, Colors.danger
    elseif style == "action-info" then
        accentColor, dimColor, glowColor = Colors.info, Colors.infoDim, Colors.info
    elseif style == "action-success" then
        accentColor, dimColor, glowColor = Colors.success, Colors.successDim, Colors.success
    elseif style == "action-warning" then
        accentColor, dimColor, glowColor = Colors.warning, Colors.warningDim, Colors.warning
    else
        accentColor, dimColor, glowColor = Colors.info, Colors.infoDim, Colors.info
    end

    local btn = Instance.new("TextButton")
    btn.Name = config.id or "GlowBtn"
    btn.Size = UDim2.new(1, 0, 0, 58)
    btn.BackgroundColor3 = Colors.bgCard
    btn.BorderSizePixel = 0
    btn.Text = ""
    btn.AutoButtonColor = false
    btn.Parent = ScrollFrame
    MakeCorner(btn, 12)
    MakeStroke(btn, accentColor, 1, isToggleOn and 0.7 or 0.94)
    AddGlow(btn, glowColor, UDim2.new(1, 30, 1, 16), UDim2.new(-0.05, -15, -0.05, -8))
    AddInnerGlow(btn, glowColor, 0, 0.5)

    local padding = MakePadding(btn, 14, 11, 14, 11)

    -- Icon box
    local iconBox = Instance.new("Frame")
    iconBox.Size = UDim2.new(0, 36, 0, 36)
    iconBox.BackgroundColor3 = dimColor
    iconBox.BorderSizePixel = 0
    iconBox.Parent = btn
    MakeCorner(iconBox, 8)

    if isToggleOn then
        AddGlow(iconBox, glowColor, UDim2.new(1, 14, 1, 14), UDim2.new(-0.2, -7, -0.2, -7))
    end

    local iconLabel = Instance.new("TextLabel")
    iconLabel.Size = UDim2.new(1, 0, 1, 0)
    iconLabel.BackgroundTransparency = 1
    iconLabel.Text = config.icon or "◆"
    iconLabel.TextColor3 = accentColor
    iconLabel.TextScaled = true
    iconLabel.Font = Enum.Font.GothamBold
    iconLabel.Parent = iconBox

    -- Text
    local mainLabel = Instance.new("TextLabel")
    mainLabel.Size = UDim2.new(1, -120, 0, 18)
    mainLabel.Position = UDim2.new(0, 50, 0, 5)
    mainLabel.BackgroundTransparency = 1
    mainLabel.Text = config.text or "Button"
    mainLabel.TextColor3 = Colors.textPrimary
    mainLabel.TextXAlignment = Enum.TextXAlignment.Left
    mainLabel.Font = Enum.Font.GothamMedium
    mainLabel.TextSize = 13
    mainLabel.Parent = btn

    if config.subtext then
        local subLabel = Instance.new("TextLabel")
        subLabel.Size = UDim2.new(1, -120, 0, 14)
        subLabel.Position = UDim2.new(0, 50, 0, 25)
        subLabel.BackgroundTransparency = 1
        subLabel.Text = config.subtext
        subLabel.TextColor3 = Colors.textMuted
        subLabel.TextXAlignment = Enum.TextXAlignment.Left
        subLabel.Font = Enum.Font.Gotham
        subLabel.TextSize = 11
        subLabel.Parent = btn
    end

    -- Status badge (for toggles)
    if config.statusText then
        local statusBg = Instance.new("Frame")
        statusBg.Size = UDim2.new(0, 36, 0, 20)
        statusBg.Position = UDim2.new(1, -50, 0.5, -10)
        statusBg.BackgroundColor3 = dimColor
        statusBg.BorderSizePixel = 0
        statusBg.Parent = btn
        MakeCorner(statusBg, 6)

        local statusLbl = Instance.new("TextLabel")
        statusLbl.Name = "StatusBadge"
        statusLbl.Size = UDim2.new(1, 0, 1, 0)
        statusLbl.BackgroundTransparency = 1
        statusLbl.Text = config.statusText
        statusLbl.TextColor3 = accentColor
        statusLbl.Font = Enum.Font.GothamBold
        statusLbl.TextSize = 10
        statusLbl.Parent = statusBg
    end

    -- Hover / press effects
    btn.MouseEnter:Connect(function() TweenButton(btn, "hover") end)
    btn.MouseLeave:Connect(function() TweenButton(btn, "release") end)
    btn.MouseButton1Down:Connect(function() TweenButton(btn, "press") end)
    btn.MouseButton1Up:Connect(function() TweenButton(btn, "release") end)

    if config.onClick then
        btn.MouseButton1Click:Connect(config.onClick)
    end

    return btn
end

