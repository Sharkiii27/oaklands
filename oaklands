-- Active indicator under tabs
local function SetActiveTab(btn)
    -- Reset all
    for _, b in ipairs(tabButtons) do
        TweenService:Create(b, TweenInfo.new(0.25), {
            BackgroundTransparency = 1,
            TextColor3 = Colors.textMuted
        }):Play()
        local ind = b:FindFirstChild("Indicator")
        if ind then
            TweenService:Create(ind, TweenInfo.new(0.25), {BackgroundTransparency = 1, Size = UDim2.new(0.4, 0, 0, 2)}):Play()
        end
    end

    TweenService:Create(btn, TweenInfo.new(0.25), {
        BackgroundTransparency = 0.9,
        TextColor3 = Colors.accent
    }):Play()

    local indicator = btn:FindFirstChild("Indicator")
    if not indicator then
        indicator = Instance.new("Frame")
        indicator.Name = "Indicator"
        indicator.Size = UDim2.new(0.4, 0, 0, 2)
        indicator.Position = UDim2.new(0.3, 0, 1, -2)
        indicator.BackgroundColor3 = Colors.accent
        indicator.BorderSizePixel = 0
        indicator.BackgroundTransparency = 1
        indicator.Parent = btn
        MakeCorner(indicator, 2)
        AddGlow(indicator, Colors.accent, UDim2.new(2, 0, 8, 0), UDim2.new(-0.5, 0, -3.5, 0))
    end

    TweenService:Create(indicator, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
        BackgroundTransparency = 0,
        Size = UDim2.new(0.5, 0, 0, 2.5)
    }):Play()

    tabButtons.active = btn
end

